# Twilio credentials — get from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Your server's public URL (use ngrok for local dev)
# Run: ngrok http 8000  → then paste the https URL here
SERVER_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Client name — the person the AI is calling on behalf of
CLIENT_NAME=Raju
